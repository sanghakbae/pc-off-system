PORT=4500
HOST=0.0.0.0
PMON_PUBLIC_BASE_URL=https://pcoff.sanghak.kr
AGENT_TOKEN=change-me-pmon-token

# PostgreSQL
DATABASE_URL=
PGSSLMODE=disable

# Firebase Admin / Google OAuth API protection
# Set PMON_AUTH_REQUIRED=true only after Firebase Admin credentials are configured.
PMON_AUTH_REQUIRED=false
PMON_ALLOWED_EMAILS=
PMON_ALLOWED_DOMAINS=pcoff.sanghak.kr
FIREBASE_PROJECT_ID=pc-off-cf652
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative to the three vars above:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Cloudflare R2 CSV backups
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PREFIX=pc-off

# Cloudflare DNS management endpoints
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
